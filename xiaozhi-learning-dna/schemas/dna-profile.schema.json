        },
        "lastUpdated": {
          "type": "string",
          "format": "date",
          "description": "学习情绪维度最后更新日期"
        }
      }
    }
  },

  "required": ["meta"],

  "$defs": {
    "confidenceLevel": {
      "description": "结论置信度标签：防止数据不足时给出误导性结论。凡是基于'连续N次'得出的AI结论必须附带此标签。data_sufficient=🟢数据充分（样本量足够，时间跨度合理，规律可信）；preliminary_trend=⚠️初步判断/趋势明显（达到最低触发阈值，但仍需警惕偶然因素）；insufficient_sample=🔴样本不足（数据极少，不能作为最终结论，仅供参考）",
      "type": "string",
      "enum": [
        "data_sufficient",
        "preliminary_trend",
        "insufficient_sample"
      ]
    },

    "subjectEntry": {
      "description": "学科条目：用于强项和弱项列表",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subject": {
          "type": "string",
          "description": "学科名称",
          "examples": ["语文", "数学", "英语", "物理", "化学", "生物", "历史", "地理", "政治"]
        },
        "chapters": {
          "type": "array",
          "description": "具体章节或知识点",
          "items": { "type": "string" }
        },
        "rootCause": {
          "type": "string",
          "description": "薄弱的根本原因（仅弱项使用）"
        },
        "confidenceLevel": {
          "$ref": "#/$defs/confidenceLevel"
        }
      },
      "required": ["subject"]
    }
  }
}
