              },
              "emotionSignals": {
                "type": "array",
                "description": "观察到的情绪信号（从对话中推断的行为指标，非主观诊断）",
                "items": {
                  "type": "string",
                  "enum": ["主动提问", "主动练习", "拖延开始", "频繁说'不会'", "说'我太差了'", "说'不想学'", "中断后主动回来", "完成后的满足感表达", "答题速度快且正确率高", "答题速度慢但坚持"]
                }
              },
              "confidenceLevel": {
                "$ref": "#/$defs/confidenceLevel"
              }
            },
            "required": ["subject", "typicalEmotion"]
          }
        },
        "anxietyTriggers": {
          "description": "焦虑触发因素：从对话中识别的引发学习焦虑的具体场景（不是标签化诊断，而是场景化观察）",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "triggerType": {
                "type": "string",
                "description": "触发类型",
                "enum": ["考前焦虑", "特定知识点恐惧", "比较压力", "家长期待压力", "时间压力", "连续错误挫败"]
              },
              "subject": {
                "type": "string",
                "description": "相关学科（如适用）"
              },
              "observedSignals": {
                "type": "array",
                "description": "观察到的具体行为信号",
                "items": {
                  "type": "string"
                },
                "maxItems": 5
              },
              "occurrenceCount": {
                "type": "integer",
                "description": "出现次数",
                "minimum": 1
              },
              "firstObservedDate": {
                "type": "string",
                "format": "date"
              },
              "lastObservedDate": {
                "type": "string",
                "format": "date"
              },
              "currentStatus": {
                "type": "string",
                "description": "当前应对状态",
                "enum": ["待关注", "正在应对", "已缓解"]
              },
              "confidenceLevel": {
                "$ref": "#/$defs/confidenceLevel"
              }
            },
            "required": ["triggerType", "occurrenceCount"]
          },
          "maxItems": 10
        },
        "motivationState": {
          "description": "学习动力状态：学生当前的学习驱动力和持续性",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "driveType": {
              "type": "string",
              "description": "主要驱动类型",
              "enum": ["内驱主导（好奇心/成就感）", "混合驱动", "外驱主导（考试/家长要求）", "驱动力不足", "数据不足"]
            },
            "engagementTrend": {
              "type": "string",
              "description": "参与度趋势（近两周）",
              "enum": ["上升", "稳定", "下降", "波动", "数据不足"]
            },
            "persistencePattern": {
              "type": "string",
              "description": "坚持模式：遇到困难时的典型行为",
              "enum": ["主动求助后继续", "独立反复尝试", "容易放弃需鼓励", "回避困难内容", "数据不足"]
            },
            "confidenceLevel": {
              "$ref": "#/$defs/confidenceLevel"
            }
          }
        },
        "emotionMilestones": {
          "description": "情绪里程碑：情绪层面的重要转变时刻",
          "type": "array",
