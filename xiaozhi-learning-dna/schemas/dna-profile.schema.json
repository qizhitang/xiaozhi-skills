          "description": "有效支持策略记录：哪些情绪支持方式对这个学生有效",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "strategy": {
                "type": "string",
                "description": "策略名称",
                "enum": ["数据替代情绪（用事实消解焦虑）", "拆小步骤降低压力", "先做会做的建立信心", "肯定具体进步而非空洞鼓励", "允许暂停不强迫", "用类比降低陌生感", "限时练习建立掌控感", "对比历史数据看见成长"]
              },
